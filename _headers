# Cloudflare Pages _headers
# HTML pages: always revalidate (fixes stale JS after deploys)
/*.html
  Cache-Control: no-cache, must-revalidate

/*/
  Cache-Control: no-cache, must-revalidate

/
  Cache-Control: no-cache, must-revalidate

# Static assets: cache 1 year (they have ?v= busters)
/static/*
  Cache-Control: public, max-age=31536000, immutable
